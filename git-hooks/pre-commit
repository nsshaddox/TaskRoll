#!/bin/bash
# Pre-commit hook for Android project
# Blocks direct commits to main and runs lint + unit tests + coverage verification

set -e

# Block direct commits to main
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || true)
if [ "$BRANCH" = "main" ]; then
    echo "❌ ERROR: Direct commits to main are not allowed."
    echo "   Please create a feature branch first:"
    echo "   git checkout -b your-branch-name"
    exit 1
fi

echo "🔍 Running pre-commit checks..."

# Run lint
echo "📝 Running lint checks..."
./gradlew lintDebug --quiet

# Run unit tests
echo "🧪 Running unit tests..."
./gradlew testDebugUnitTest --quiet

# Run coverage verification
echo "📊 Running coverage verification..."
./gradlew jacocoTestCoverageVerification --quiet

# Check code style (ktlint)
echo "🎨 Checking code style (ktlint)..."
./gradlew ktlintCheck --quiet

# Run static analysis (detekt)
echo "🔬 Running static analysis (detekt)..."
./gradlew detekt --quiet

echo "✅ All checks passed! Proceeding with commit."
